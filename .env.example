# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Path to the TinyLlama GGUF model (auto-downloaded on Render)
MODEL_PATH=models/tinyllama-1.1b-chat-v1.0.Q4_K_M.gguf
MODEL_DIR=models

# Tesseract OCR binary path (Windows only; leave blank on Linux/Mac/Render)
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# Optional API keys
GEMINI_API_KEY=
TAVILY_API_KEY=

# Flask env — set to 'development' for local debug mode
FLASK_ENV=production
